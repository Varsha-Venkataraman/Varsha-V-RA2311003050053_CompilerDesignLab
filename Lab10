#include <stdio.h>
#include <ctype.h>

char stack[50];
int top = -1;

void push(char c) { stack[++top] = c; }
char pop() { return stack[top--]; }

int priority(char op) {
    if(op=='+'||op=='-') return 1;
    if(op=='*'||op=='/') return 2;
    return 0;
}

int main() {
    char exp[50];
    printf("Enter infix: ");
    scanf("%s", exp);

    printf("Postfix: ");

    for(int i=0; exp[i]; i++) {
        if(isalnum(exp[i]))
            printf("%c", exp[i]);

        else if(exp[i]=='(')
            push(exp[i]);

        else if(exp[i]==')') {
            while(stack[top] != '(')
                printf("%c", pop());
            pop();
        }

        else {
            while(top!=-1 && priority(stack[top]) >= priority(exp[i]))
                printf("%c", pop());
            push(exp[i]);
        }
    }

    while(top!=-1)
        printf("%c", pop());

    return 0;
}
