#include <stdio.h>
#include <ctype.h>
#include <string.h>

char keywords[][10] = {
    "int","float","if","else","while",
    "for","return","char","double","void"
};

int isKeyword(char word[]) {
    for(int i = 0; i < 10; i++) {
        if(strcmp(word, keywords[i]) == 0)
            return 1;
    }
    return 0;
}

int main() {
    char input[100], word[50];
    int i = 0, j;

    printf("Enter code:\n");
    fgets(input, sizeof(input), stdin);

    while(input[i] != '\0') {

        if(isalpha(input[i])) {
            j = 0;
            while(isalnum(input[i])) {
                word[j++] = input[i++];
            }
            word[j] = '\0';

            if(isKeyword(word))
                printf("%s -> Keyword\n", word);
            else
                printf("%s -> Identifier\n", word);
        }

        else if(isdigit(input[i])) {
            printf("%c -> Number\n", input[i]);
            i++;
        }

        else if(strchr("+-*/=%", input[i])) {
            printf("%c -> Operator\n", input[i]);
            i++;
        }

        else if(strchr("(){}[],;", input[i])) {
            printf("%c -> Special Symbol\n", input[i]);
            i++;
        }

        else {
            i++;
        }
    }
}
