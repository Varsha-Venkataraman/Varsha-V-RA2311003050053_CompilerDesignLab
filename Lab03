#include <stdio.h>

int main() {
    printf("Simple demonstration of NFA to DFA conversion\n");

    printf("\nExample:\n");
    printf("NFA States: {q0, q1}\n");
    printf("DFA States: { {q0}, {q0,q1}, {q1} }\n");

    printf("\nTransition Example:\n");
    printf("{q0} --a--> {q0,q1}\n");
    printf("{q0,q1} --b--> {q1}\n");

    return 0;
}
