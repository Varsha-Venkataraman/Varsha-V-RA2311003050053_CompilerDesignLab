#include <stdio.h>
#include <string.h>

int main() {
    int n, t[10][10], dfa[10][10];
    printf("Enter number of states: ");
    scanf("%d",&n);

    printf("Enter NFA transition table:\n");
    for(int i=0;i<n;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&t[i][j]);

    printf("\nDFA Table:\n");
    for(int i=0;i<n;i++) {
        for(int j=0;j<2;j++) {
            dfa[i][j] = t[i][j]; // simplified
            printf("%d ", dfa[i][j]);
        }
        printf("\n");
    }
    return 0;
}
