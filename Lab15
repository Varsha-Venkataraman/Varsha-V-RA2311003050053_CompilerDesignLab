#include <stdio.h>

int stack[50], top=-1;

void push(int x) {
    stack[++top] = x;
    printf("Pushed %d\n", x);
}

void pop() {
    if(top==-1) printf("Underflow\n");
    else printf("Popped %d\n", stack[top--]);
}

int main() {
    push(10);
    push(20);
    push(30);

    pop();
    pop();

    return 0;
}
