#include <stdio.h>

int main() {
    int stack[5], top = -1;

    printf("Pushing elements...\n");

    for(int i = 0; i < 5; i++) {
        stack[++top] = i;
        printf("Pushed %d\n", i);
    }

    printf("\nPopping elements...\n");

    while(top >= 0) {
        printf("Popped %d\n", stack[top--]);
    }

    return 0;
}
