#include <stdio.h>
#include <string.h>

int main() {
    char input[20], stack[20];
    int top = -1;

    printf("Enter string: ");
    scanf("%s", input);

    printf("\nShift Reduce Process:\n");

    for(int i = 0; i < strlen(input); i++) {
        stack[++top] = input[i];
        stack[top+1] = '\0';

        printf("Shift: %s\n", stack);

        if(stack[top] == 'i') {
            stack[top] = 'E';
            printf("Reduce: %s\n", stack);
        }
    }

    return 0;
}
